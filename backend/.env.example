APP_NAME=vybe-shortener
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me
BASE_URL=http://localhost:5000

# Preferred: set DATABASE_URL and individual vars are not needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon_db
# Or set individual vars (only used if DATABASE_URL is not set):
# DATABASE_NAME=hackathon_db
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
DB_MAX_CONNECTIONS=20
DB_STALE_TIMEOUT_SECONDS=300
DB_CONNECTION_TIMEOUT_SECONDS=10

DEFAULT_SHORT_CODE_LENGTH=7
MAX_CUSTOM_ALIAS_LENGTH=32
MAX_URL_LENGTH=2048
DEFAULT_REDIRECT_STATUS_CODE=302
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
AUTH_ENABLED=false
API_AUTH_TOKEN=
API_AUTH_TOKENS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=500 per minute
RATE_LIMIT_WRITE=120 per minute
EXPOSE_ERROR_DETAILS=false
# Redis is auto-enabled when REDIS_URL is set
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_BACKOFF_SECONDS=0.05

# Observability
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
